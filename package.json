    "cross-env": "^7.0.3",
    "isbot": "^3.6.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^3",
    "@remix-run/dev": "^1.16.1",
    "@types/react": "^18.2.7",
    "@types/react-dom": "^18.2.4",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.0.4",
    "wrangler": "^3.0.1"
  }
}
